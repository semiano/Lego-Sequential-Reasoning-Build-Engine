{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlannerStepPlan",
  "type": "object",
  "required": [
    "intent",
    "region_focus",
    "micro_assembly_guidance",
    "target_part_count",
    "stop_signal"
  ],
  "properties": {
    "intent": { "type": "string", "minLength": 3 },
    "region_focus": { "type": "string", "minLength": 2 },
    "micro_assembly_guidance": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "type": "string", "minLength": 2 }
    },
    "target_part_count": { "type": "integer", "minimum": 3, "maximum": 20 },
    "stop_signal": { "type": "boolean" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
